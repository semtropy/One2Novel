generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ────────────────────────────────────────────

enum ChapterStatus {
  unplanned
  planned
  drafting
  drafted
  reviewing
  needs_repair
  completed
}

enum ProjectProgressStatus {
  not_started
  in_progress
  completed
  blocked
}

enum NarrativePov {
  first_person
  third_person
  mixed
}

// ─── Core: Novel ──────────────────────────────────────

model Novel {
  id          String  @id @default(cuid())
  title       String
  description String?
  status      String  @default("draft") // draft | active | completed
  writingMode String  @default("original") // original | continuation

  // Book framing (editorial / market info)
  genre                 String?
  targetAudience        String?
  bookSellingPoint      String?
  competingFeel         String?
  first30ChapterPromise String?
  commercialTags        String?
  titleSuggestions      String?

  // ── Unified story core (replaces DraftStorySeed + fragmented columns) ──
  storySummary    String? // 故事简介：合并 premise + mainArc（80-300字）
  centralQuestion String? // 核心悬念：合并 mysteryBox + finalSecret（50-150字）
  endingDirection String? // 结局方向：含 finalEnemy + ultimateForm 描述（50-150字）

  // Creative parameters
  narrativePov          NarrativePov?
  pacePreference        String? // slow | balanced | fast
  tonePitch             String?  @map("styleTone")  // renamed: "tone" describes prose register, not StyleProfile engine
  emotionIntensity      String? // low | medium | high
  defaultChapterLength  Int?
  estimatedChapterCount Int?

  // Long-form web novel (the only mode)
  writingScale       String  @default("long")
  architectureType   String? // skill_slot | sequence_promotion | case_driven | cultivation_planning | historical_transmigration | custom
  loopSkeleton       String? // JSON: LoopSkeleton
  loopDefinition     String? // JSON: user-customized loop phase definitions
  goldenFinger       String? // JSON: {goldenFingerName, abilities:string[], limits:string[]}
  powerSystemTree    String? // JSON: PowerNode[] — cultivation level / sequence tree
  expectationProfile String? // JSON: ExpectationProfile
  contentBeatProfile String?  // JSON: ContentBeatProfile — 内容节拍配方

  // Blueprint — volume→chapter structure
  structuredOutline  String? /// @deprecated Use loopSkeleton + volumes instead. Legacy blueprint JSON — kept for backward compat.
  directorCheckpoint String? // JSON DirectorCheckpoint for batch-write resume
  pipelineState      String? // JSON PipelineState — 7-step creation pipeline progress

  // Progress
  projectStatus ProjectProgressStatus @default(not_started)

  // Style
  postGenerationStyleReviewEnabled Boolean @default(true)

  // Relations
  chapters           Chapter[]
  characters         NovelCharacter[]
  volumes            Volume[]
  chapterSummaries   ChapterSummary[]
  auditReports       AuditReport[]
  timelineItems      TimelineItem[]
  payoffItems        PayoffLedgerItem[]
  worldRules         WorldRule[]
  characterResources CharacterResource[]
  infoProfiles       CharacterInfoProfile[]
  volumePresences    CharacterVolumePresence[]
  referenceBook      ReferenceBook?
  activeProfileId    String?
  activeProfile      ReferenceProfile?         @relation("ActiveProfile", fields: [activeProfileId], references: [id])
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
}

// ─── Chapter ──────────────────────────────────────────

model Chapter {
  id               String        @id @default(cuid())
  novelId          String
  title            String
  content          String? // Full chapter text (markdown)
  order            Int
  chapterStatus    ChapterStatus @default(unplanned)
  targetWordCount  Int           @default(3000)
  actualWordCount  Int?
  qualityScore     Float? // 0-80 scale
  openingScore     Int?
  plotScore        Int?
  characterScore   Int?
  dialogueScore    Int?
  suspenseScore    Int?
  pacingScore      Int?
  showNotTellScore Int?
  languageScore    Int?
  genreScore       Int?
  coherenceScore   Int?
  activeWorldRules String? // JSON array: rule IDs active for this chapter
  hook             String? // Chapter end hook text
  expectation      String? // What this chapter should achieve
  repairHistory    String? // JSON repair log
  diagnosis        String? // JSON WorkspaceDiagnosis
  riskFlags        String? // JSON string array

  scenePlan            String? // JSON {scenes:[...], enabled:bool}
  openConflicts        String? // JSON {conflicts:[...]}
  finalizationSnapshot String? // JSON {snapshotVersion,timestamp,...}

  // Relations
  novel                Novel                  @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterSummary       ChapterSummary?
  auditReports         AuditReport[]
  volumeChapterPlans   VolumeChapterPlan[]
  timelineItems        TimelineItem[]
  editHistory          ChapterEditHistory[]
  acquiredResources    CharacterResource[]    @relation("ResourceAcquiredIn")
  depletedResources    CharacterResource[]    @relation("ResourceDepletedIn")
  revealedInfoProfiles CharacterInfoProfile[] @relation("InfoProfileRevealedIn")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@unique([novelId, order])
  @@index([novelId, chapterStatus])
}

model ChapterEditHistory {
  id         String   @id @default(cuid())
  chapterId  String
  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  content    String // 编辑前正文快照
  sceneState String? // 当时的 scenePlan 快照
  createdAt  DateTime @default(now())

  @@index([chapterId, createdAt])
}

model ChapterSummary {
  id              String   @id @default(cuid())
  novelId         String
  chapterId       String   @unique
  summary         String
  keyEvents       String? // JSON array
  characterStates String? // JSON map
  hook            String?
  chapter         Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([novelId])
}

// ─── Volume Planning ──────────────────────────────────

model Volume {
  id             String              @id @default(cuid())
  novelId        String
  sortOrder      Int
  title          String
  summary        String?
  openingHook    String?
  mainPromise    String?
  climax         String?
  nextVolumeHook String?
  novel          Novel               @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterPlans   VolumeChapterPlan[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([novelId, sortOrder])
}

model VolumeChapterPlan {
  id              String   @id @default(cuid())
  volumeId        String
  chapterId       String?
  chapterOrder    Int
  title           String
  summary         String?
  purpose         String?
  exclusiveEvent  String?
  endingState     String?
  conflictLevel   Int?
  revealLevel     Int?
  targetWordCount Int?
  mustAvoid       String?
  // Phase 0: Long-form loop + rhythm tracking
  loopPhase       String? // "trigger"|"enter"|"explore"|"setback"|"turn"|"climax"|"settlement"
  loopIndex       Int? // 属于第几轮回环
  coolPointType   String? // "collect"|"strategy"|"verify"|"face_slap"|"reveal"|"upgrade"
  hookType        String? // "short_term"|"medium_term"
  chapterType     String? // "advance"|"transition"|"cooldown"|"climax"
  contentBeat     String? // 内容节拍类型，如"修炼"/"显圣"/"赚钱"/"恋爱"/"日常"/"过渡"/"说明"
  chapter         Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  volume          Volume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([volumeId, chapterOrder])
}

// ─── Characters ───────────────────────────────────────

model NovelCharacter {
  id                 String                    @id @default(cuid())
  novelId            String
  name               String
  role               String // protagonist | antagonist | supporting | minor
  personality        String?
  background         String?
  // Hard facts
  identityLabel      String?
  factionLabel       String?
  stanceLabel        String?
  powerLevel         String?
  realm              String?
  currentLocation    String?
  availability       String?
  prohibitions       String? // Natural language: "禁止背叛师父、禁止在战斗中逃跑"
  loopFunctionTag    String? // 副本触发器 | 奖励来源 | 伏笔载体 | 长期威胁 | 情感锚点
  // Appearance
  appearance         String? // 外貌体态着装一句话 (30-80字)
  quirks             String? // 1-2个标志性习惯动作 (10-30字)
  // Profile
  currentState       String?
  currentStatus      String? // 角色当前状态快照 (10-40字)
  currentGoal        String?
  voiceTexture       String?
  presenceImpression String?
  // Meta
  novel              Novel                     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  relations_source   NovelCharacterRelation[]  @relation("SourceCharacter")
  relations_target   NovelCharacterRelation[]  @relation("TargetCharacter")
  ownedResources     CharacterResource[]
  knownInfo          CharacterInfoProfile[]
  volumePresences    CharacterVolumePresence[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([novelId, role])
}

model NovelCharacterRelation {
  id                String         @id @default(cuid())
  novelId           String
  sourceCharacterId String
  targetCharacterId String
  type              String // friend | enemy | lover | rival | mentor | family
  summary           String?
  trustScore        Float?
  intimacyScore     Float?
  conflictScore     Float?
  dependencyScore   Float?
  attitudeSource    String? // How source feels about target
  attitudeTarget    String? // How target feels about source
  historySummary    String? // How they met, key shared events
  currentTension    String? // Current state of tension
  stage             String? // strangers|acquainted|allied|conflicted|estranged|reconciled
  volumePresence    String? // JSON: which volumes they matter in
  sourceCharacter   NovelCharacter @relation("SourceCharacter", fields: [sourceCharacterId], references: [id], onDelete: Cascade)
  targetCharacter   NovelCharacter @relation("TargetCharacter", fields: [targetCharacterId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([novelId, sourceCharacterId, targetCharacterId])
  @@index([novelId])
  @@index([sourceCharacterId])
  @@index([targetCharacterId])
}

// ─── Phase 0: Character Volume Presence (long-form role lifecycle) ─

model CharacterVolumePresence {
  id             String         @id @default(cuid())
  novelId        String
  characterId    String
  volumeOrder    Int // 第几卷
  presence       String         @default("active") // "active" | "inactive" | "returning" | "departing"
  trajectoryNote String? // 本卷的角色弧线描述
  novel          Novel          @relation(fields: [novelId], references: [id], onDelete: Cascade)
  character      NovelCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([novelId, characterId, volumeOrder])
  @@index([novelId, volumeOrder])
}

// ─── Phase 0: Reference Book (competitor analysis) ─

model ReferenceBook {
  id              String   @id @default(cuid())
  novelId         String
  fileName        String
  totalChapters   Int?
  content         String? // 文本内容（可能很大）
  annotations     String? // JSON: 分析标注（分析结果暂存此处，save-profile后迁移到ReferenceProfile）
  writingAssets   String? // JSON: 写法技法
  analysisSummary String? // JSON: 分析摘要（兼容旧代码）
  profileId       String?  // 关联的分析档案
  profile         ReferenceProfile? @relation("ProfileBooks", fields: [profileId], references: [id], onDelete: SetNull)
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([novelId])
}

model ReferenceProfile {
  id                String   @id @default(cuid())
  name              String   // 参考书名称
  architectureType  String?  // 检测到的架构类型
  totalChapters     Int?     // 总章数
  loopBoundaries    String?  // JSON: 回环边界
  coolPointDensity  String?  // JSON: 爽点分布
  hookPatterns      String?  // JSON: 钩子模式
  goldenFingerBounds String? // JSON: 金手指提取
  contentBeatPatterns String?// JSON: 内容节拍DNA
  writingAssets     String?  // JSON: 写法技法
  settingTimeline   String?  // JSON: 设定时间线
  books             ReferenceBook[]         @relation("ProfileBooks")
  novels            Novel[]                @relation("ActiveProfile")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ─── Phase 12: Character Depth ─────────────────────────

model CharacterResource {
  id                  String         @id @default(cuid())
  novelId             String
  ownerId             String
  name                String
  category            String
  description         String?
  acquiredInChapterId String?
  depletedInChapterId String?
  status              String         @default("active")
  constraints         String?
  novel               Novel          @relation(fields: [novelId], references: [id], onDelete: Cascade)
  owner               NovelCharacter @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  acquiredInChapter   Chapter?       @relation("ResourceAcquiredIn", fields: [acquiredInChapterId], references: [id], onDelete: SetNull)
  depletedInChapter   Chapter?       @relation("ResourceDepletedIn", fields: [depletedInChapterId], references: [id], onDelete: SetNull)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([novelId, ownerId])
}

model CharacterInfoProfile {
  id                  String         @id @default(cuid())
  novelId             String
  knowerId            String
  subject             String
  content             String
  certainty           String         @default("certain")
  revealedInChapterId String?
  novel               Novel          @relation(fields: [novelId], references: [id], onDelete: Cascade)
  knower              NovelCharacter @relation(fields: [knowerId], references: [id], onDelete: Cascade)
  revealedInChapter   Chapter?       @relation("InfoProfileRevealedIn", fields: [revealedInChapterId], references: [id], onDelete: SetNull)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([novelId, knowerId])
}

// ─── Quality Audit ────────────────────────────────────

model AuditReport {
  id           String       @id @default(cuid())
  novelId      String
  chapterId    String
  auditType    String // acceptance | timeline | style
  overallScore Float?
  summary      String? // Human-facing summary
  details      String? // JSON structured details
  status       String       @default("pending") // pending | passed | warning | failed
  novel        Novel        @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter      Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  issues       AuditIssue[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([chapterId, auditType])
  @@index([novelId])
}

model AuditIssue {
  id            String      @id @default(cuid())
  reportId      String
  type          String // continuity | character | plot | style | pacing | dialogue
  severity      String // low | medium | high | critical
  description   String
  evidence      String?
  fixSuggestion String?
  status        String      @default("open") // open | resolved | ignored
  report        AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ─── Style Engine ─────────────────────────────────────

model StyleProfile {
  id                String         @id @default(cuid())
  name              String
  description       String?
  category          String? // uploaded | extracted | manual
  sourceText        String?
  extractedFeatures String? // JSON: LLM-extracted features
  narrativeRules    String? // JSON
  languageRules     String? // JSON
  characterRules    String? // JSON
  rhythmRules       String? // JSON
  antiAiRules       String? // JSON
  selfCheckRules    String? // JSON
  bindings          StyleBinding[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model StyleBinding {
  id             String       @id @default(cuid())
  styleProfileId String
  targetType     String // novel | chapter
  targetId       String
  priority       Int          @default(0)
  weight         Float        @default(1.0)
  enabled        Boolean      @default(true)
  styleProfile   StyleProfile @relation(fields: [styleProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([targetType, targetId])
}

// ─── Payoff / Foreshadowing ───────────────────────────

model PayoffLedgerItem {
  id               String   @id @default(cuid())
  novelId          String
  ledgerKey        String
  title            String
  summary          String?
  scopeType        String // book | volume | chapter
  currentStatus    String // setup | hinted | pending_payoff | paid_off | failed | overdue
  targetStartOrder Int?
  targetEndOrder   Int?
  firstSeenOrder   Int?
  lastTouchedOrder Int?
  setupChapterId   String?
  payoffChapterId  String?
  statusReason     String?
  novel            Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([novelId, ledgerKey])
  @@index([novelId, currentStatus])
}

// ─── Timeline ─────────────────────────────────────────

model TimelineItem {
  id          String   @id @default(cuid())
  novelId     String
  chapterId   String?
  title       String
  description String?
  sortOrder   Int
  category    String   @default("event") // event | deadline | milestone | constraint
  status      String   @default("pending") // pending | active | resolved | violated
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter     Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([novelId, sortOrder])
}

// ─── World Rules ──────────────────────────────────────

model WorldRule {
  id            String   @id @default(cuid())
  novelId       String
  category      String // 势力格局|力量体系|资源规则|社会结构|地理环境|历史背景
  title         String
  content       String // 10-50 chars, executable rule
  priority      Int      @default(0) // Higher = more important for conflict detection
  status        String   @default("active") // active|deprecated|conflicted
  conflictsWith String? // JSON array of conflicting rule IDs
  activatedAt   String? // JSON array of chapter IDs
  novel         Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([novelId, category])
  @@index([novelId, status])
}
